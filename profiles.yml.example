approvalmax_ai_platform_v2:
  target: dev
  outputs:
    dev:
      type: databricks
      catalog: workspace
      schema: approvalmax_v2_gold
      host: "{{ env_var('DATABRICKS_HOST') }}"
      http_path: "/sql/1.0/warehouses/<WAREHOUSE_ID>"
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      threads: 4

