          },
          "position": {
            "x": 0,
            "y": 1,
            "width": 6,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "document-count",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "document_summary",
                  "fields": [
                    {
                      "name": "document_count",
                      "expression": "`document_count`"
                    }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "document_count",
                  "displayName": "Documents"
                }
              },
              "frame": {
