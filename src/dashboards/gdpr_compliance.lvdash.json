{
  "datasets": [
    {
      "name": "gdpr_compliance_summary",
      "displayName": "GDPR Compliance Summary",
      "queryLines": [
        "SELECT ",
        "  (SELECT COUNT(DISTINCT company_id) FROM approvalmax_ai_platform.gold.fact_approval_document_lifecycle) AS represented_client_count, ",
        "  (SELECT COUNT(*) FROM approvalmax_ai_platform.monitoring.tenant_change_log WHERE lower(change_type) RLIKE 'erase|erasure|forgotten|delete|deletion') AS erasure_event_count, ",
        "  (SELECT COUNT(*) FROM approvalmax_ai_platform.monitoring.dashboard_quality_status WHERE status <> 'passed') AS open_quality_exception_count, ",
        "  (SELECT COUNT(*) FROM approvalmax_ai_platform.monitoring.etl_audit_log WHERE status <> 'success') AS failed_processing_event_count "
      ]
    },
    {
      "name": "gdpr_individual_rights_evidence",
      "displayName": "Individual Rights Evidence",
      "queryLines": [
        "WITH rights AS ( ",
        "  SELECT 'Right of access' AS right_name, 'access|subject access|dsar' AS pattern ",
        "  UNION ALL SELECT 'Right to rectification', 'rectification|correct|correction' ",
        "  UNION ALL SELECT 'Right to erasure / forgotten', 'erasure|forgotten|erase|delete|deletion' ",
        "  UNION ALL SELECT 'Right to restrict processing', 'restrict|restriction' ",
        "  UNION ALL SELECT 'Right to data portability', 'portability|portable|export' ",
        "  UNION ALL SELECT 'Right to object', 'object|objection' ",
        "  UNION ALL SELECT 'Automated decision-making review', 'automated|profiling|decision' ",
        ") ",
        "SELECT ",
        "  r.right_name, ",
        "  COUNT(t.change_type) AS evidence_event_count, ",
        "  CASE WHEN COUNT(t.change_type) > 0 THEN 'evidence_present' ELSE 'no_request_evidence' END AS evidence_status ",
        "FROM rights r ",
        "LEFT JOIN approvalmax_ai_platform.monitoring.tenant_change_log t ",
        "  ON lower(concat_ws(' ', t.change_type, t.component, t.description)) RLIKE r.pattern ",
        "GROUP BY r.right_name ",
        "ORDER BY r.right_name "
      ]
    },
    {
      "name": "gdpr_processing_inventory",
      "displayName": "Processing Inventory",
      "queryLines": [
        "SELECT ",
        "  target_layer, ",
        "  target_table, ",
        "  COUNT(*) AS processing_event_count, ",
        "  SUM(CASE WHEN status = 'success' THEN 1 ELSE 0 END) AS successful_event_count, ",
        "  SUM(COALESCE(failed_row_count, 0)) AS failed_row_count, ",
        "  MAX(ended_at) AS last_processed_at ",
        "FROM approvalmax_ai_platform.monitoring.etl_audit_log ",
        "GROUP BY target_layer, target_table ",
        "ORDER BY last_processed_at DESC ",
        "LIMIT 30 "
      ]
    },
    {
      "name": "gdpr_retention_review",
      "displayName": "Retention Review",
      "queryLines": [
        "SELECT ",
        "  company_id, ",
        "  company_name, ",
        "  COUNT(*) AS document_count, ",
        "  MIN(created_at) AS oldest_document_at, ",
        "  MAX(updated_at) AS latest_update_at, ",
        "  SUM(CASE WHEN created_at < add_months(current_date(), -84) THEN 1 ELSE 0 END) AS candidate_retention_review_count ",
        "FROM approvalmax_ai_platform.gold.fact_approval_document_lifecycle ",
        "GROUP BY company_id, company_name ",
        "ORDER BY candidate_retention_review_count DESC, oldest_document_at ASC "
      ]
    },
    {
      "name": "gdpr_quality_evidence",
      "displayName": "Quality and Accuracy Evidence",
      "queryLines": [
        "SELECT ",
        "  expectation_name, ",
        "  status, ",
        "  severity, ",
        "  failed_row_count, ",
        "  checked_at, ",
        "  details ",
        "FROM approvalmax_ai_platform.monitoring.dashboard_quality_status ",
        "ORDER BY checked_at DESC ",
        "LIMIT 30 "
      ]
    },
    {
      "name": "gdpr_control_coverage",
      "displayName": "GDPR Control Coverage",
      "queryLines": [
        "SELECT 'DSAR intake register' AS control_name, 'missing_source_table' AS evidence_status, 'No dedicated data subject request table exists in this bundle yet.' AS evidence_detail ",
        "UNION ALL SELECT 'Right to be forgotten execution proof', CASE WHEN EXISTS (SELECT 1 FROM approvalmax_ai_platform.monitoring.tenant_change_log WHERE lower(change_type) RLIKE 'erase|erasure|forgotten|delete|deletion') THEN 'evidence_present' ELSE 'no_request_evidence' END, 'Uses tenant_change_log keyword evidence until a formal erasure register is modelled.' ",
        "UNION ALL SELECT 'Consent and lawful basis register', 'missing_source_table', 'No consent/legal-basis register table exists in this bundle yet.' ",
        "UNION ALL SELECT 'Retention schedule monitoring', 'partial_evidence', 'Uses document age from Gold lifecycle table; no policy-specific retention table exists yet.' ",
        "UNION ALL SELECT 'Data portability fulfilment evidence', 'missing_source_table', 'No portability export/audit table exists in this bundle yet.' ",
        "UNION ALL SELECT 'Restriction and objection handling', 'missing_source_table', 'No restriction/objection workflow table exists in this bundle yet.' ",
        "UNION ALL SELECT 'Automated decision-making review', 'missing_source_table', 'No automated decisioning/profiling registry exists in this bundle yet.' ",
        "UNION ALL SELECT 'Data quality and accuracy evidence', 'evidence_present', 'Uses Great Expectations-style results from monitoring.dashboard_quality_status.' "
      ]
    }
  ],
