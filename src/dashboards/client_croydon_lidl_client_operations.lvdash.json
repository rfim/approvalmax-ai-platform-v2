{
  "datasets": [
    {
      "name": "lidl_document_summary",
      "displayName": "Lidl Document Summary",
      "queryLines": [
        "SELECT ",
        "  COUNT(*) AS document_count, ",
        "  AVG(approval_cycle_time_minutes) AS avg_approval_cycle_time_minutes, ",
        "  SUM(approval_sla_breach_flag) AS sla_breach_count, ",
        "  SUM(total_amount) AS total_document_value ",
        "FROM approvalmax_ai_platform.gold.fact_approval_document_lifecycle "
      ]
    },
    {
      "name": "lidl_documents_by_status",
      "displayName": "Lidl Documents by Status",
      "queryLines": [
        "SELECT ",
        "  document_status, ",
        "  COUNT(*) AS document_count, ",
        "  SUM(total_amount) AS total_document_value, ",
        "  AVG(approval_cycle_time_minutes) AS avg_cycle_minutes ",
        "FROM approvalmax_ai_platform.gold.fact_approval_document_lifecycle ",
        "GROUP BY document_status ",
        "ORDER BY document_count DESC "
      ]
    },
    {
      "name": "lidl_company_performance",
      "displayName": "Lidl Company Performance",
      "queryLines": [
        "SELECT ",
        "  company_id, ",
        "  company_name, ",
        "  COUNT(*) AS document_count, ",
        "  SUM(total_amount) AS total_document_value, ",
        "  AVG(approval_cycle_time_minutes) AS avg_cycle_minutes, ",
        "  SUM(approval_sla_breach_flag) AS sla_breach_count ",
        "FROM approvalmax_ai_platform.gold.fact_approval_document_lifecycle ",
        "GROUP BY company_id, company_name ",
        "ORDER BY total_document_value DESC ",
        "LIMIT 10 "
      ]
    },
    {
      "name": "lidl_supplier_exposure",
      "displayName": "Lidl Supplier Exposure",
      "queryLines": [
        "SELECT ",
        "  supplier_name, ",
        "  COUNT(*) AS document_count, ",
        "  SUM(total_amount) AS total_document_value, ",
        "  AVG(approval_cycle_time_minutes) AS avg_cycle_minutes ",
        "FROM approvalmax_ai_platform.gold.fact_approval_document_lifecycle ",
        "GROUP BY supplier_name ",
        "ORDER BY total_document_value DESC ",
        "LIMIT 10 "
      ]
    },
    {
      "name": "lidl_document_detail",
      "displayName": "Lidl Document Detail",
      "queryLines": [
        "SELECT ",
        "  document_id, ",
        "  company_name, ",
        "  supplier_name, ",
        "  document_status, ",
        "  total_amount, ",
        "  approval_cycle_time_minutes, ",
        "  approval_sla_breach_flag, ",
        "  submitted_at, ",
        "  approved_at ",
        "FROM approvalmax_ai_platform.gold.fact_approval_document_lifecycle ",
        "ORDER BY approved_at DESC ",
        "LIMIT 50 "
      ]
    },
    {
      "name": "lidl_quality_status",
      "displayName": "Lidl Quality Status",
      "queryLines": [
        "SELECT ",
        "  expectation_name, ",
        "  status, ",
        "  severity, ",
        "  failed_row_count, ",
        "  checked_at ",
        "FROM approvalmax_ai_platform.monitoring.dashboard_quality_status ",
        "ORDER BY checked_at DESC ",
        "LIMIT 20 "
      ]
    }
  ],
